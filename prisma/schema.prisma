generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────

enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum UserRole {
  USER
  ADMIN
}

enum ReviewType {
  TRACK
  ALBUM
}

enum ContentStatus {
  ACTIVE
  HIDDEN
  DELETED
}

enum ReactionType {
  LIKE
  DISLIKE
}

enum NotificationType {
  LIKE
  DISLIKE
  COMMENT
  FOLLOW
  MODERATION
  FOLLOW_REQUEST
  FOLLOW_REQUEST_ACCEPTED
}

enum ReportTargetType {
  REVIEW
  COMMENT
  USER
}

enum ReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum FollowRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum CatalogResourceType {
  ARTIST
  ALBUM
  TRACK
}

// ─── User & Auth ─────────────────────────────────────────────────

model User {
  id              String     @id @default(uuid())
  handle          String     @unique
  displayName     String
  email           String     @unique
  passwordHash    String?
  googleId        String?    @unique
  avatarUrl       String?
  avatarPublicId  String?
  coverUrl        String?
  coverPublicId   String?
  bio             String?
  notifEnabled    Boolean    @default(true)
  isPrivate       Boolean    @default(false)
  status          UserStatus @default(ACTIVE)
  role            UserRole   @default(USER)
  consentedAt     DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  // Sistema de penalización escalonada (docs/musicbox.md §15)
  acceptedReportsCount Int       @default(0)
  penaltyLevel         Int       @default(0)
  penalizedUntil       DateTime?

  following                Follow[]                  @relation("Follower")
  followers                Follow[]                  @relation("Followee")
  reviews                  Review[]
  reactions                ReviewReaction[]
  comments                 Comment[]
  notificationsReceived    Notification[]            @relation("Recipient")
  notificationsActed       Notification[]            @relation("Actor")
  notifPreference          NotificationPreference?
  refreshTokens            RefreshToken[]
  reports                  Report[]
  reportsReviewed          Report[]                  @relation("ReportReviewer")
  recommendationSnapshot   RecommendationSnapshot?
  followSuggestionSnapshot FollowSuggestionSnapshot?
  followRequestsSent       FollowRequest[]           @relation("FollowRequester")
  followRequestsReceived   FollowRequest[]           @relation("FollowRequestTarget")
  catalogSearchHistory     CatalogSearchHistory[]
  userSearchHistory        UserSearchHistory[]
  recentlyViewedItems      RecentlyViewedItem[]

  @@map("users")
}

model Follow {
  followerId String
  followeeId String
  createdAt  DateTime @default(now())

  follower User @relation("Follower", fields: [followerId], references: [id])
  followee User @relation("Followee", fields: [followeeId], references: [id])

  @@id([followerId, followeeId])
  @@map("follows")
}

// Máquina de estados por par (requester, target) — una sola fila que se
// resetea a PENDING si se vuelve a pedir seguir tras un rechazo, en vez de
// acumular filas históricas (ver docs/fase-7-features.md, sección de
// perfiles privados).
model FollowRequest {
  id          String              @id @default(uuid())
  requesterId String
  targetId    String
  status      FollowRequestStatus @default(PENDING)
  createdAt   DateTime            @default(now())
  respondedAt DateTime?

  requester User @relation("FollowRequester", fields: [requesterId], references: [id])
  target    User @relation("FollowRequestTarget", fields: [targetId], references: [id])

  @@unique([requesterId, targetId])
  @@map("follow_requests")
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ip        String?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

// ─── Catalog (cache de Deezer) ────────────────────────────────────

model Artist {
  id              String    @id @default(uuid())
  deezerId        String    @unique
  mbid            String?   @unique
  name            String
  imageUrl        String?
  lastSyncedAt    DateTime
  // Set only when the full discography (all albums + tracks) has been
  // walked and persisted — distinct from lastSyncedAt, which any partial
  // upsert (e.g. a lone getArtist() call) also touches.
  catalogSyncedAt DateTime?

  albums Album[]
  tracks Track[]

  @@map("artists")
}

model Album {
  id           String    @id @default(uuid())
  deezerId     String    @unique
  mbid         String?   @unique
  title        String
  artistId     String
  coverUrl     String?
  releaseDate  DateTime?
  genreLabel   String?
  lastSyncedAt DateTime

  artist  Artist   @relation(fields: [artistId], references: [id])
  tracks  Track[]
  reviews Review[]

  @@map("albums")
}

model Track {
  id           String   @id @default(uuid())
  deezerId     String   @unique
  mbid         String?  @unique
  title        String
  albumId      String?
  artistId     String
  durationMs   Int?
  trackNumber  Int?
  previewUrl   String?
  lastSyncedAt DateTime

  album            Album?            @relation(fields: [albumId], references: [id])
  artist           Artist            @relation(fields: [artistId], references: [id])
  reviews          Review[]
  trackReviewItems TrackReviewItem[]

  @@map("tracks")
}

// ─── Reviews ─────────────────────────────────────────────────────

model Review {
  id          String        @id @default(uuid())
  userId      String
  type        ReviewType
  trackId     String?
  albumId     String?
  description String
  rating      Decimal       @db.Decimal(3, 1)
  status      ContentStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  deletedAt   DateTime?

  externalTitle      String
  externalArtistName String
  externalCoverUrl   String?

  user             User              @relation(fields: [userId], references: [id])
  track            Track?            @relation(fields: [trackId], references: [id])
  album            Album?            @relation(fields: [albumId], references: [id])
  trackReviewItems TrackReviewItem[]
  reactions        ReviewReaction[]
  comments         Comment[]
  notifications    Notification[]

  @@map("reviews")
}

model TrackReviewItem {
  id          String  @id @default(uuid())
  reviewId    String
  trackId     String
  rating      Int
  description String?
  position    Int

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  track  Track  @relation(fields: [trackId], references: [id])

  @@unique([reviewId, trackId])
  @@map("track_review_items")
}

// ─── Social ───────────────────────────────────────────────────────

model ReviewReaction {
  id        String       @id @default(uuid())
  userId    String
  reviewId  String
  type      ReactionType
  createdAt DateTime     @default(now())

  user   User   @relation(fields: [userId], references: [id])
  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@unique([userId, reviewId])
  @@map("review_reactions")
}

model Comment {
  id        String        @id @default(uuid())
  userId    String
  reviewId  String
  content   String
  status    ContentStatus @default(ACTIVE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt
  deletedAt DateTime?

  user          User           @relation(fields: [userId], references: [id])
  review        Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  notifications Notification[]

  @@map("comments")
}

// ─── Notificaciones ───────────────────────────────────────────────

model Notification {
  id          String           @id @default(uuid())
  recipientId String
  actorId     String?
  type        NotificationType
  reviewId    String?
  commentId   String?
  actorCount  Int?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  recipient User     @relation("Recipient", fields: [recipientId], references: [id], onDelete: Cascade)
  actor     User?    @relation("Actor", fields: [actorId], references: [id])
  review    Review?  @relation(fields: [reviewId], references: [id], onDelete: SetNull)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: SetNull)

  @@map("notifications")
}

model NotificationPreference {
  userId                 String  @id
  likesEnabled           Boolean @default(true)
  dislikesEnabled        Boolean @default(true)
  commentsEnabled        Boolean @default(true)
  followsEnabled         Boolean @default(true)
  // Perfiles privados (post-Fase 7) — distinta de followsEnabled: gatea
  // FOLLOW_REQUEST (solicitud entrante) y FOLLOW_REQUEST_ACCEPTED (tu
  // solicitud saliente fue aceptada). Solo una de las dos es configurable
  // por usuario según User.isPrivate (ver UsersService).
  followRequestsEnabled  Boolean @default(true)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

// ─── Moderación ───────────────────────────────────────────────────

model Report {
  id           String           @id @default(uuid())
  reporterId   String
  targetType   ReportTargetType
  targetId     String
  reason       String
  status       ReportStatus     @default(PENDING)
  reviewedById String?
  reviewedAt   DateTime?
  createdAt    DateTime         @default(now())

  reporter User  @relation(fields: [reporterId], references: [id])
  reviewer User? @relation("ReportReviewer", fields: [reviewedById], references: [id])

  @@map("reports")
}

// ─── Recomendaciones ──────────────────────────────────────────────

model RecommendationSnapshot {
  userId      String   @id
  payload     Json
  generatedAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("recommendation_snapshots")
}

// ─── Follow suggestions ───────────────────────────────────────────

model FollowSuggestionSnapshot {
  userId      String   @id
  payload     Json
  generatedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("follow_suggestion_snapshots")
}

// ─── Trending ──────────────────────────────────────────────────────

model TrendingSnapshot {
  id         String   @id @default(uuid())
  payload    Json
  snapshotAt DateTime @default(now())

  @@map("trending_snapshots")
}

// ─── Historial de búsquedas y vistos recientes ────────────────────

model CatalogSearchHistory {
  id         String   @id @default(uuid())
  userId     String
  query      String
  searchedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, query])
  @@map("catalog_search_history")
}

model UserSearchHistory {
  id         String   @id @default(uuid())
  searcherId String
  query      String
  searchedAt DateTime @default(now())

  searcher User @relation(fields: [searcherId], references: [id], onDelete: Cascade)

  @@unique([searcherId, query])
  @@map("user_search_history")
}

// Denormalizado (título/artista/cover/albumsCount capturados al momento de
// la visita), mismo precedente que Review.externalTitle/externalArtistName —
// evita un join de vuelta a Artist/Album/Track en cada GET.
model RecentlyViewedItem {
  id           String              @id @default(uuid())
  userId       String
  resourceType CatalogResourceType
  deezerId     String
  title        String
  artistName   String?
  coverUrl     String?
  albumsCount  Int?
  viewedAt     DateTime            @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, resourceType, deezerId])
  @@map("recently_viewed_items")
}
