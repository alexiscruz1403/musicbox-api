# ─── Base de datos (Supabase) ─────────────────────────────────────
# Pooler URL para queries de la aplicación (transaction pooler)
DATABASE_URL=postgresql://user:password@host:5432/musicbox
# Conexión directa para Prisma Migrate (requerido con Supabase / PgBouncer)
DIRECT_URL=postgresql://user:password@direct-host:5432/musicbox
# Conexión de pg-boss (bus de jobs). DEBE ser session-mode/direct — el
# transaction pooler (6543) NO sirve (pg-boss maneja su propio schema y estado
# de sesión). Usar el session pooler de Supabase o la conexión directa. Si se
# omite, cae a DIRECT_URL y luego a DATABASE_URL.
PGBOSS_DATABASE_URL=postgresql://user:password@direct-host:5432/musicbox

# ─── Redis (Upstash) — solo caché de catálogo + rate limiting ────
# Usar rediss:// para TLS (requerido en Upstash)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ─── JWT ─────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── OAuth Google ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@vinlyst.app

# ─── URLs ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── APIs externas ────────────────────────────────────────────────
DEEZER_BASE_URL=https://api.deezer.com
LASTFM_BASE_URL=http://ws.audioscrobbler.com/2.0
LASTFM_API_KEY=
MUSICBRAINZ_CONTACT_EMAIL=contacto@vinlyst.app

# ─── Observabilidad (Sentry) ──────────────────────────────────────
# DSN del proyecto Sentry. Vacío = Sentry inerte (no se inicializa).
SENTRY_DSN=
# Muestreo de trazas de performance (0–1). Los errores se capturan al 100%.
SENTRY_TRACES_SAMPLE_RATE=0.1
# Release (SHA de git) para atribuir issues a una versión. En Render se puede
# dejar vacío: instrument.ts usa RENDER_GIT_COMMIT como fallback.
SENTRY_RELEASE=

# ─── Web Push (VAPID) ─────────────────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:soporte@vinlyst.app

# ─── Idempotencia ─────────────────────────────────────────────────
# TTL del cache de Idempotency-Key en Redis, en segundos (default 72h,
# pensado para reintentos de escrituras encoladas offline)
IDEMPOTENCY_TTL_SECONDS=259200

# ─── Servidor ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
# Expone la doc OpenAPI en GET /v1/docs. Dejar en false en producción.
SWAGGER_ENABLED=false
