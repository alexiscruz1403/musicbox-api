# ─── Base de datos ────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/musicbox

# ─── Redis ───────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── OAuth Google ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── APIs externas ────────────────────────────────────────────────
DEEZER_BASE_URL=https://api.deezer.com
LASTFM_API_KEY=
MUSICBRAINZ_CONTACT_EMAIL=contacto@musicbox.app

# ─── Observabilidad ───────────────────────────────────────────────
SENTRY_DSN=

# ─── Servidor ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
