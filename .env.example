# ─── Base de datos (Supabase) ─────────────────────────────────────
# Pooler URL para queries de la aplicación
DATABASE_URL=postgresql://user:password@host:5432/musicbox
# Conexión directa para Prisma Migrate (requerido con Supabase / PgBouncer)
DIRECT_URL=postgresql://user:password@direct-host:5432/musicbox

# ─── Redis (Upstash) ─────────────────────────────────────────────
# Usar rediss:// para TLS (requerido en Upstash)
REDIS_URL=rediss://default:password@host.upstash.io:6379

# ─── JWT ─────────────────────────────────────────────────────────
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_EXPIRES_IN=7d

# ─── OAuth Google ─────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Cloudinary ───────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Email (SMTP) ─────────────────────────────────────────────────
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@musicbox.app

# ─── URLs ─────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── APIs externas ────────────────────────────────────────────────
DEEZER_BASE_URL=https://api.deezer.com
LASTFM_BASE_URL=http://ws.audioscrobbler.com/2.0
LASTFM_API_KEY=
MUSICBRAINZ_CONTACT_EMAIL=contacto@musicbox.app

# ─── Observabilidad ───────────────────────────────────────────────
SENTRY_DSN=

# ─── Servidor ─────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
